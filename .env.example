# =============================================================================
# Environment variables for the Deepfake Forensics Engine.
#
# Usage:
#   1. Copy this file:        cp .env.example .env
#   2. Fill in the values you need (everything is optional — defaults are safe).
#   3. docker-compose up      # the stack will pick up .env automatically.
#
# .env is in .gitignore — never commit it. .env.example is the version
# control'd template; keep it in sync with code that reads new vars.
# =============================================================================

# ── Engine API ──────────────────────────────────────────────────────────────

# Comma-separated list of accepted X-API-Key values. Empty = no auth, any
# client can hit the API. Set this for any non-local deployment.
# Example: ENGINE_API_KEYS=devkey-9b3c,demo-7f2e
ENGINE_API_KEYS=

# Sliding-window rate limit per API key (or per IP when no key configured).
# Lower = stricter. Tune higher for benchmark/demo runs that fire many
# requests in a burst.
ENGINE_RATE_LIMIT_PER_MIN=10

# Upload size cap in MEGABYTES. Requests with a Content-Length above this
# are rejected before reading the body. Cap exists so an attacker can't
# fill /tmp with a single multi-GB POST.
ENGINE_MAX_UPLOAD_MB=200

# ── Sightengine cloud detector (optional) ───────────────────────────────────

# Whether the Sightengine plugin runs at all. Off by default — the free
# tier is 2000 ops/month and a single video burns ~100 ops, so this would
# starve the quota in <20 demo runs if left on.
SIGHTENGINE_ENABLED=false

# Credentials from https://dashboard.sightengine.com/api-credentials .
# Only consulted when SIGHTENGINE_ENABLED=true.
SIGHTENGINE_API_USER=
SIGHTENGINE_API_SECRET=

# ── Frontend ────────────────────────────────────────────────────────────────

# When ENGINE_API_KEYS is set, the dashboard must include the same value
# on every request. Pick ONE of the keys configured in ENGINE_API_KEYS
# above. Empty = no auth header sent (matches default backend behaviour).
#
# Variables prefixed with NEXT_PUBLIC_ are inlined into the browser
# bundle at build time, so changing this requires re-running
# `docker compose build frontend` — `docker compose restart` is not
# enough.
NEXT_PUBLIC_ENGINE_API_KEY=
